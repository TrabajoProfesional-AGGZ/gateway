{
  "version": 3,
  "name": "SocioUnido API Gateway",
  "port": 8080,
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "extra_config": {
    "security/cors": {
      "allow_origins": [
        "{{ env `FRONTEND_URL` }}",
        "http://localhost:3000"
      ],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Origin", "Authorization", "Content-Type"],
      "expose_headers": ["Content-Length"],
      "max_age": "12h"
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/v1/health",
      "method": "GET",
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com",
          "issuer": "https://securetoken.google.com/{{ env `FIREBASE_PROJECT_ID` }}",
          "audience": ["{{ env `FIREBASE_PROJECT_ID` }}"],
          "disable_jwk_security": true
        },
        "proxy": {
          "modify": {
            "headers": {
              "X-Internal-Secret": ["{{ env `INTERNAL_SECRET_TOKEN` }}"]
            }
          }
        }
      },      
      "backend": [
        {
          "url_pattern": "/health",
          "method": "GET",
          "host": ["{{ env `MS_CLUB_URL` }}"]
        }
      ]
    },
    {
      "endpoint": "/api/v1/socios/{dni}",
      "method": "GET",
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com",
          "issuer": "https://securetoken.google.com/{{ env `FIREBASE_PROJECT_ID` }}",
          "audience": ["{{ env `FIREBASE_PROJECT_ID` }}"],
          "disable_jwk_security": true
        },
        "proxy": {
          "modify": {
            "headers": {
              "X-Internal-Secret": ["{{ env `INTERNAL_SECRET_TOKEN` }}"]
            }
          }
        }
      },
      "backend": [
        {
          "url_pattern": "/socios/{dni}",
          "method": "GET",
          "host": ["{{ env `MS_CLUB_URL` }}"]
        }
      ]
    },
    {
      "endpoint": "/api/v1/socios",
      "method": "GET",
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com",
          "issuer": "https://securetoken.google.com/{{ env `FIREBASE_PROJECT_ID` }}",
          "audience": ["{{ env `FIREBASE_PROJECT_ID` }}"],
          "disable_jwk_security": true
        },
        "proxy": {
          "modify": {
            "headers": {
              "X-Internal-Secret": ["{{ env `INTERNAL_SECRET_TOKEN` }}"]
            }
          }
        }
      },
      "backend": [
        {
          "url_pattern": "/socios",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": ["{{ env `MS_CLUB_URL` }}"]
        }
      ]
    },
    {
      "endpoint": "/api/docs/club",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/docs",
          "encoding": "no-op",
          "sd": "static",
          "method": "GET",
          "host": ["{{ env `MS_CLUB_URL` }}"]
        }
      ]
    },
    {
      "endpoint": "/openapi.json",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/openapi.json",
          "encoding": "no-op",
          "sd": "static",
          "method": "GET",
          "host": ["{{ env `MS_CLUB_URL` }}"]
        }
      ]
    }
  ]
}